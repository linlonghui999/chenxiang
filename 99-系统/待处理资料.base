filters:
  and:
    - file.ext == "md"
    - or:
        - status == "待整理"
        - status == "待提炼"
properties:
  file.name:
    displayName: 笔记
  domain:
    displayName: 领域
  category:
    displayName: 分类
  status:
    displayName: 状态
  file.mtime:
    displayName: 最后修改
views:
  - type: table
    name: 待整理与待提炼
    groupBy:
      property: domain
      direction: ASC
    order:
      - file.name
      - domain
      - category
      - status
      - file.mtime
